// Esquema de la base de datos — Intranet COMPROINT
// Modela usuarios, organigrama (áreas/sub-áreas), documentos,
// proyectos y anuncios. Campos alineados 1:1 con src/types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id          String  @id
  nombre      String
  email       String  @unique
  password    String
  rol         String
  cargo       String
  areaSlug    String?
  subareaSlug String?
  avatarColor String
  activo      Boolean @default(true)
}

model Area {
  slug        String    @id
  nombre      String
  descripcion String
  icono       String
  subareas    SubArea[]
}

model SubArea {
  id       Int    @id @default(autoincrement())
  areaSlug String
  slug     String
  nombre   String
  area     Area   @relation(fields: [areaSlug], references: [slug], onDelete: Cascade)

  @@unique([areaSlug, slug])
}

model Documento {
  id               String  @id
  codigo           String? // código correlativo ISO (ej. CAL-PRC-001), generado por la app
  nombre           String
  tipo             String
  categoria        String
  areaSlug         String
  subareaSlug      String?
  fechaSubida      String
  autor            String
  estado           String
  confidencialidad String
  version          String
  tamano           String
  proyectoSlug     String?
  storagePath      String? // ruta del archivo en Supabase Storage
  mime             String? // tipo MIME del archivo
  soloVista        Boolean @default(false) // solo vista previa (sin descarga)
  eliminado        Boolean @default(false) // papelera (borrado lógico, reversible)
  eliminadoEn      String? // ISO de cuándo se envió a la papelera
  eliminadoPor     String? // nombre de quien lo eliminó
  fechaAprobacion       String? // YYYY-MM-DD en que se aprobó (control de vigencia ISO)
  fechaProximaRevision  String? // YYYY-MM-DD límite para revisarlo (calculada)
  periodoRevisionMeses  Int?    // cada cuántos meses se revisa
  avisoVencimiento      Boolean @default(false) // ya se notificó "por vencer"
  requiereAcuse         Boolean @default(false) // exige acuse de lectura (ISO)

  @@index([areaSlug, fechaSubida])
  @@index([areaSlug, subareaSlug])
  @@index([proyectoSlug])
  @@unique([codigo])
  @@index([eliminado])
  @@index([fechaProximaRevision])
}

model Proyecto {
  slug        String @id
  nombre      String
  descripcion String
  estado      String
}

model Anuncio {
  id        String  @id
  titulo    String
  cuerpo    String
  fecha     String
  autor     String
  prioridad String
  areaSlug  String? // null = anuncio para toda la empresa (Gerencia); si no, solo esa área
}

// Bitácora de auditoría — quién hizo qué y cuándo (trazabilidad ISO 9001).
model Auditoria {
  id            String @id @default(cuid())
  fecha         String // ISO
  usuarioId     String
  usuarioNombre String
  rol           String
  accion        String // subió, descargó, vio, editó, eliminó, publicó, inició sesión…
  entidad       String // documento, proyecto, carpeta, usuario, anuncio, sesión
  detalle       String // nombre/título del elemento afectado
  areaSlug      String?

  @@index([fecha])
  @@index([usuarioId])
}

// Acuse de lectura ("leído y entendido") — distribución controlada ISO 9001.
model AcuseLectura {
  id          String @id @default(cuid())
  documentoId String
  usuarioId   String
  fecha       String // ISO

  @@unique([documentoId, usuarioId])
  @@index([documentoId])
}

// Historial de versiones de un documento (cada reemplazo guarda la anterior).
model DocumentoVersion {
  id          String @id @default(cuid())
  documentoId String
  version     String
  storagePath String
  mime        String
  tamano      String
  autor       String
  fecha       String

  @@index([documentoId])
}

// Notificaciones por usuario.
model Notificacion {
  id        String  @id @default(cuid())
  usuarioId String
  titulo    String
  cuerpo    String
  url       String?
  fecha     String
  leida     Boolean @default(false)

  @@index([usuarioId, leida])
  @@index([usuarioId, fecha])
}
