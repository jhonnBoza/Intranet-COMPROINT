# Plantilla de variables de entorno — COPIA a .env y completa con tus valores.
# NUNCA subas el archivo .env real al repositorio (ya está en .gitignore).

# --- Base de datos (Supabase Postgres) ---
# Supabase → Connect → ORM (Prisma). Reemplaza [PASSWORD] y verifica el host.
DATABASE_URL="postgresql://postgres.TU_PROYECTO:[PASSWORD]@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.TU_PROYECTO:[PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres"

# --- Sesiones ---
# Genera uno nuevo con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="genera-un-secreto-largo-y-aleatorio"

# --- Almacenamiento de archivos (Supabase Storage) ---
# Supabase → Settings → API Keys → Secret keys (sb_secret_...)
SUPABASE_URL="https://TU_PROYECTO.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
